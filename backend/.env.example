# ─── AFTERLIGHT Backend Environment Configuration ──────────────────────────────
# Copy this file to .env and fill in your values

# ─── Ollama / Gemma 4 ─────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma4:e2b
# Pull this model first: ollama pull gemma4:e2b

# ─── Adapter Fine-Tuning (HuggingFace Gemma 4 E2B IT) ─────────────────────────
# Must be the real Gemma 4 model. Script will REFUSE to train on anything else.
HF_GEMMA4_MODEL=google/gemma-4-e2b-it
# Or provide a local path: HF_GEMMA4_MODEL=/path/to/gemma-4-e2b-it

# ─── Embedding Model (runs locally, no API needed) ────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BASE=./storage

# ─── Application ───────────────────────────────────────────────────────────────
APP_NAME=Afterlight
DEBUG=false
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Tesseract OCR Path (Windows default) ─────────────────────────────────────
# Leave empty if tesseract is in your PATH
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# ─── FFmpeg Path ──────────────────────────────────────────────────────────────
# Leave empty if ffmpeg is in your PATH
# FFMPEG_BIN=ffmpeg
# FFPROBE_BIN=ffprobe
